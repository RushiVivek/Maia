{
  "tasks": {
    "dev": "deno run --watch --allow-net --allow-env --env-file main.ts",
    "start": "deno run --allow-net --allow-env main.ts",
    "test": "deno test --allow-net=api.github.com --allow-env",
    "check": "deno check main.ts",
    "fmt": "deno fmt",
    "lint": "deno lint"
  },
  "imports": {
    "@noble/ciphers/": "jsr:/@noble/ciphers@2.2.0/",
    "@noble/hashes/": "jsr:/@noble/hashes@2.2.0/",
    "@msgpack/msgpack": "npm:@msgpack/msgpack@3.1.3",
    "@std/assert": "jsr:@std/assert@1.0.19",
    "@std/crypto/timing-safe-equal": "jsr:@std/crypto@1.1.0/timing-safe-equal",
    "@std/encoding": "jsr:@std/encoding@1.0.10"
  },
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true
  },
  "fmt": {
    "lineWidth": 100
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "lock": true
}
