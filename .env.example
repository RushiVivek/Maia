# maia configuration — copy to .env for local dev (.env is gitignored).
# In production these are set as Deno Deploy environment variables.

# GitHub repo that holds the atlas vault (the PRIMARY repo for github-mirror vaults).
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-vault-repo

# The atlas vault id (the <vault_id> in tags `atlas-root-<vault_id>` / `atlas-chunk-<vault_id>-NNNNNN`).
ATLAS_VAULT_ID=

# Fine-grained, READ-ONLY PAT scoped to just the vault repo(s). Server-side only — never sent to the browser.
GITHUB_TOKEN=

# Bearer token clients must present on every request. Generate a long random value, e.g.:
#   openssl rand -hex 32
AUTH_TOKEN=

# Optional: listen port for local dev (Deno Deploy sets PORT itself). Defaults to 8000.
# PORT=8000
